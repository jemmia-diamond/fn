generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma-cli"
  previewFeatures = ["driverAdapters", "queryCompiler"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["ecom", "haravan", "larksuite", "misa", "pancake", "payment", "public"]
}
